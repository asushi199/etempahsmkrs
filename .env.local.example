# ====== Konfigurasi Supabase ======
# Salin fail ini kepada .env.local dan isi nilai sebenar dari projek Supabase anda.
# Dapatkan nilai di: Supabase Dashboard > Project Settings > API

# URL projek Supabase (cth: https://abcdxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Service role key (RAHSIA — hanya digunakan di pelayan, jangan dedahkan kepada pelayar)
SUPABASE_SERVICE_ROLE_KEY=

# ====== Kata laluan pentadbir ======
# Kata laluan untuk masuk ke halaman Tetapan (/admin) — urus bilik, logo, nama sistem.
ADMIN_PASSWORD=tukar-kata-laluan-ini
